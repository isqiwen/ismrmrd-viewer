# =============================================================================
# Universal .gitignore template
# C++ / Python / CMake / Make / GCC / Clang / Visual Studio
#
# Reusable baseline for cross-platform development:
# - ignore generated files, caches, local IDE state, compiler outputs
# - keep source-controlled build scripts and project metadata visible
#
# Intentionally NOT ignored:
# - CMakeLists.txt
# - CMakePresets.json
# - Makefile / GNUmakefile
# - pyproject.toml / setup.py / requirements*.txt
# - .clang-format / .clang-tidy / .editorconfig
# =============================================================================

# -----------------------------------------------------------------------------
# OS / filesystem noise
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100/
.Trashes/
.fseventsd
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.directory
.Trash-*/
.fuse_hidden*
.nfs*
.apdisk

# -----------------------------------------------------------------------------
# Editor / IDE local state
# -----------------------------------------------------------------------------
.vs/
.idea/
*.iml
*.swp
*.swo
*~
*.tmp
*.temp
*.bak
*.orig
*.rej

# VS Code: ignore local state, allow shareable repo config when needed
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace

# Visual Studio user-specific state
*.sln
*.vcproj
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.vcxitems
*.vcxitems.filters
*.shproj
*.suo
*.user
*.userosscache
*.rsuser
*.sln.docstates
*.VC.db
*.VC.VC.opendb
*.VC.opendb
*.opendb
*.opensdf
*.sdf
*.ncb
*.aps
*.cachefile
*.ipch
ipch/
*.tlog
*.tlog/
*.lastbuildstate
*.unsuccessfulbuild

# Xcode / macOS IDE user state
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcuserdatad/
*.xcuserstate

# -----------------------------------------------------------------------------
# Local environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template

